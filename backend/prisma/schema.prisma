generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  decks        Deck[]
  pathProgress UserPathProgress[]
  quizAttempts QuizAttempt[]
  goalSetting  UserGoalSetting?
  dailyProgress UserDailyProgress[]
}

model UserGoalSetting {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyCardTarget Int      @default(20)
  timezone        String   @default("Asia/Ho_Chi_Minh")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserDailyProgress {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime
  reviewedCards Int     @default(0)
  quizAttempts Int      @default(0)
  goalTarget   Int      @default(20)
  goalAchieved Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model Deck {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  sourceTopicId String?
  sourceTopic   VocabularyTopic?  @relation(fields: [sourceTopicId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  cards         Card[]

  @@index([userId])
  @@index([sourceTopicId])
}

model VocabularyTopic {
  id           String           @id @default(cuid())
  title        String
  description  String?
  languageCode String           @default("ko")
  level        String?
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  words        VocabularyWord[]
  derivedDecks Deck[]
  pathSteps    LearningPathStep[]

  @@index([languageCode])
  @@index([level])
}

model VocabularyWord {
  id        String          @id @default(cuid())
  topicId   String
  topic     VocabularyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  frontText String
  backText  String
  note      String?
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([topicId])
}

enum GrammarLevel {
  BEGINNER_1
  BEGINNER_2
  INTERMEDIATE_1
  INTERMEDIATE_2
  ADVANCED_1
  ADVANCED_2
}

model GrammarLesson {
  id        String            @id @default(cuid())
  level     GrammarLevel
  title     String
  summary   String?
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  vocabulary LessonVocabulary[]
  points    GrammarPoint[]
  exercises GrammarExercise[]
  pathSteps LearningPathStep[]

  @@index([level])
}

enum LearningPathStepType {
  TOPIC
  LESSON
}

model LearningPath {
  id          String              @id @default(cuid())
  title       String
  description String?
  languageCode String            @default("ko")
  level       String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  steps       LearningPathStep[]
  progress    UserPathProgress[]

  @@index([languageCode])
  @@index([level])
}

model LearningPathStep {
  id        String               @id @default(cuid())
  pathId    String
  path      LearningPath         @relation(fields: [pathId], references: [id], onDelete: Cascade)
  type      LearningPathStepType
  title     String
  summary   String?
  topicId   String?
  topic     VocabularyTopic?     @relation(fields: [topicId], references: [id], onDelete: SetNull)
  lessonId  String?
  lesson    GrammarLesson?       @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  sortOrder Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([pathId])
  @@index([topicId])
  @@index([lessonId])
}

model UserPathProgress {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathId            String
  path              LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  completedStepIds  String[]     @default([])
  startedAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
}

model LessonVocabulary {
  id        String        @id @default(cuid())
  lessonId  String
  lesson    GrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  frontText String
  backText  String
  note      String?
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([lessonId])
}

model GrammarPoint {
  id          String        @id @default(cuid())
  lessonId    String
  lesson      GrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title       String
  meaning     String?
  structure   String?
  example     String?
  translation String?
  note        String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([lessonId])
}

model GrammarExercise {
  id           String        @id @default(cuid())
  lessonId     String
  lesson       GrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  prompt       String
  options      String[]
  correctIndex Int
  explanation  String?
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([lessonId])
}

model Card {
  id             String    @id @default(cuid())
  deckId         String
  deck           Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  frontText      String
  backText       String
  note           String?
  sortOrder      Int       @default(0)
  correctCount   Int       @default(0)
  wrongCount     Int       @default(0)
  streak         Int       @default(0)
  lastResult     Boolean?
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([deckId])
  @@index([nextReviewAt])
}

enum QuizSourceType {
  DECK
  TOPIC
  LESSON
  PATH
}

model QuizAttempt {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceType     QuizSourceType
  sourceId       String
  sourceTitle    String
  totalQuestions Int
  correctAnswers Int
  scorePercent   Int
  createdAt      DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([sourceType, sourceId])
}
