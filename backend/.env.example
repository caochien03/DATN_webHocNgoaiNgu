# PostgreSQL — đổi user, password, host, port, tên DB cho đúng môi trường
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/DATN?schema=public"

PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# JWT — dùng chuỗi dài, ngẫu nhiên trên môi trường thật (không commit giá trị thật vào repo công khai)
JWT_SECRET="change-me-to-a-long-random-string-in-production"
# Thời hạn access token (giây), mặc định 7 ngày nếu bỏ trống
JWT_EXPIRES_SEC=604800
